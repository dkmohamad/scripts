# Follow sourced files
external-sources=true

# SC1091: Can't follow dynamic source paths — expected with our
#         source "$VAR/file.sh" pattern.
disable=SC1091

# SC2034: "Variable appears unused" false positives for variables
#         set before sourcing (LOG_TAG) or in env files.
disable=SC2034

# SC2153: "Possible misspelling" false positives for variables
#         defined in sourced config files.
disable=SC2153
