# Configuration for the recorder pipeline.
# Sourced by bash helpers and lib.py (Python).
SUMMARY_MODEL=claude-haiku-4-5-20251001
MAX_DURATION_SECS=5400
RECORDINGS_DIR=~/Recordings
MEETING_PREFIX=capture
MIC_FILE=mic.wav
SYS_FILE=system.wav
MIC_MP3=mic.mp3
SYS_MP3=system.mp3
TRANSCRIPT_FILE=transcript.txt
SUMMARY_FILE=summary.txt
TITLE_FILE=title.txt
# Stitch whisper segments together when the silence between them is shorter
# than this; break a new line only on a longer pause. 0.7s is the sentence/
# utterance boundary from Campione & Veronis (2002) pause-duration research.
MERGE_GAP_SECS=0.7
